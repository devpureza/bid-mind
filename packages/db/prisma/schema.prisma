// =============================================================================
// BidMind — Prisma schema (SQLite, ambiente de dev)
//
// ATENÇÃO: isto é a variante DEV. O DESIGN.mnd §7 manda Postgres 16 + pgvector;
// ao chegar no Marco 3 (AGENT1-01 precisa embeddings + BullMQ/Redis), voltamos
// para o schema original. O snapshot Postgres está preservado em
// `prisma/migrations.postgres.archive/` para referência e re-aplicação.
//
// Divergências em relação ao DESIGN.mnd §6, só pra suportar SQLite:
//   • `provider = "sqlite"` (era "postgresql" + extensão `vector`)
//   • Sem `@db.Uuid`, `@db.VarChar`, `@db.Text`, `@db.SmallInt` (SQLite é TEXT/INTEGER)
//   • Enums convertidos em `String` — Prisma não suporta enum com SQLite
//     (os valores válidos continuam tipados em `packages/types/src/index.ts`)
//   • `Json` vira TEXT com serialização automática do Prisma
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Tenants e usuários
// -----------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  nome      String
  plano     String   @default("free")
  createdAt DateTime @default(now()) @map("created_at")

  users      User[]
  licitacoes Licitacao[]
  arquivos   Arquivo[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String   @unique
  role         String   @default("analista") // UserRole em packages/types
  passwordHash String?  @map("password_hash") // null quando user veio só por OAuth
  nome         String?
  createdAt    DateTime @default(now()) @map("created_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licitacoesCriadas Licitacao[]     @relation("LicitacaoCreatedBy")
  passwordResets    PasswordReset[]
  oauthAccounts     OauthAccount[]

  @@index([tenantId])
  @@map("users")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model OauthAccount {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  provider       String // "google" por enquanto
  providerUserId String   @map("provider_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

// -----------------------------------------------------------------------------
// Licitações
// -----------------------------------------------------------------------------

model Licitacao {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  titulo         String
  orgaoLicitante String?   @map("orgao_licitante")
  prazoProposta  DateTime? @map("prazo_proposta")
  status         String    @default("aguardando_edital") // LicitacaoStatus em packages/types
  createdById    String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("LicitacaoCreatedBy", fields: [createdById], references: [id])
  arquivos   Arquivo[]
  contexto   LicitacaoContexto?
  agenteLogs AgenteLog[]

  @@index([tenantId, status])
  @@index([prazoProposta])
  @@map("licitacoes")
}

// -----------------------------------------------------------------------------
// Arquivos (editais, propostas, orçamentos, templates)
// `tenantId` sempre presente; `licitacaoId` nulo para templates (RF-09).
// -----------------------------------------------------------------------------

model Arquivo {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  licitacaoId  String?  @map("licitacao_id")
  tipo         String // ArquivoTipo em packages/types
  storageKey   String   @map("storage_key")
  nomeOriginal String   @map("nome_original")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licitacao Licitacao? @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)

  @@index([tenantId, tipo])
  @@index([licitacaoId])
  @@map("arquivos")
}

// -----------------------------------------------------------------------------
// Contexto compartilhado entre agentes
// 1:1 com licitação. Campos JSON (TEXT em SQLite) com saídas dos agentes.
// -----------------------------------------------------------------------------

model LicitacaoContexto {
  id                String   @id @default(uuid())
  licitacaoId       String   @unique @map("licitacao_id")
  editalEstruturado Json?    @map("edital_estruturado")
  propostaTecnica   Json?    @map("proposta_tecnica")
  orcamento         Json?
  updatedAt         DateTime @updatedAt @map("updated_at")

  licitacao Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)

  @@map("licitacao_contexto")
}

// -----------------------------------------------------------------------------
// Logs dos agentes (RNF-06: auditoria de prompts/respostas)
// -----------------------------------------------------------------------------

model AgenteLog {
  id          String   @id @default(uuid())
  licitacaoId String   @map("licitacao_id")
  agente      Int // 1 | 2 | 3
  status      String // AgenteStatus em packages/types
  prompt      String?
  resposta    String?
  duracaoMs   Int?     @map("duracao_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  licitacao Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)

  @@index([licitacaoId, agente, createdAt])
  @@map("agente_logs")
}
