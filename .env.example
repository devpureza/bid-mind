# =============================================================================
# BidMind — Variáveis de ambiente (template)
# Copie para `.env` e preencha com valores reais. NUNCA commitar `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Geral
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL 16 + pgvector)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://bidmind:bidmind@localhost:5432/bidmind?schema=public

# -----------------------------------------------------------------------------
# Redis (filas BullMQ + cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
JWT_SECRET=changeme-please-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth Google (opcional — AUTH-01)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/google/callback

# -----------------------------------------------------------------------------
# OpenAI (Agentes de IA — gpt-4o-mini para MVP/testes)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Cloudflare R2 (storage de editais, propostas e templates)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bidmind-dev
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# -----------------------------------------------------------------------------
# E-mail (recuperação de senha / convite de usuário)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="BidMind <noreply@bidmind.com.br>"

# -----------------------------------------------------------------------------
# Workers / processamento
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=2
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_MAX_FILES_PER_LICITACAO=50
